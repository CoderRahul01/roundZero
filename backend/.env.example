# Core
ENVIRONMENT=production
LOG_LEVEL=info
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1
RATE_LIMIT_MAX=8
RATE_LIMIT_WINDOW_SECONDS=60
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
JWT_SECRET=roundzero-super-secret-key

# APIs
ANTHROPIC_API_KEY=
STREAM_API_KEY=
STREAM_API_SECRET=

# Data & Storage
PINECONE_API_KEY=
PINECONE_INDEX=interview-questions
MONGODB_URI=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE=
SUPERMEMORY_API_KEY=
GEMINI_API_KEY=

# Neon Auth (recommended)
NEON_AUTH_URL=
NEON_AUTH_JWKS_URL=
NEON_AUTH_ISSUER=
NEON_AUTH_AUDIENCE=
ALLOW_LEGACY_HS256_AUTH=true

# Feature flags
USE_PINECONE=false
USE_CLAUDE_DECISION=false
USE_SUPERMEMORY=false
