# RoundZero AI Interview Coach - Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================================================
# CORE CONFIGURATION
# ============================================================================

# Environment: development, staging, production
ENVIRONMENT=production

# Logging level: debug, info, warning, error, critical
LOG_LEVEL=info

# CORS allowed origins (comma-separated)
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173

# Allowed hosts for the application
ALLOWED_HOSTS=*

# Rate limiting configuration
RATE_LIMIT_MAX=8
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL Database URL (Neon)
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://user:password@host.neon.tech/database?sslmode=require

# Neon Auth Configuration
NEON_AUTH_PROJECT_ID=your-neon-project-id
NEON_AUTH_URL=https://your-project.neonauth.region.aws.neon.tech/database/auth
NEON_AUTH_JWKS_URL=https://your-project.neonauth.region.aws.neon.tech/database/auth/.well-known/jwks.json
NEON_AUTH_ISSUER=https://your-project.neonauth.region.aws.neon.tech/database/auth
NEON_AUTH_AUDIENCE=https://your-project.neonauth.region.aws.neon.tech
ALLOW_LEGACY_HS256_AUTH=false

# MongoDB Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/?appName=AppName
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=RoundZero

# JWT Secret for authentication
JWT_SECRET=your-super-secret-jwt-key-change-this

# ============================================================================
# STREAM.IO WEBRTC CONFIGURATION
# ============================================================================

# Stream.io credentials for video calling
# Get these from: https://getstream.io/dashboard/
STREAM_APP_ID=your-stream-app-id
STREAM_API_KEY=your-stream-api-key
STREAM_API_SECRET=your-stream-api-secret

# ============================================================================
# AI / LLM SERVICES
# ============================================================================

# Anthropic Claude API Key (for interview decision-making and orchestration)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-api-key

# Google Gemini API Key (for emotion detection and embeddings)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Groq API Key (optional, for free-tier alternative to Claude)
# Get from: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key

# ============================================================================
# VECTOR DATABASE & MEMORY
# ============================================================================

# Pinecone API Key (for question semantic search)
# Get from: https://app.pinecone.io/
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=interview-questions

# Supermemory API Key (for candidate memory and session summaries)
# Get from: https://supermemory.ai/
SUPERMEMORY_API_KEY=your-supermemory-api-key

# ============================================================================
# CACHING & RATE LIMITING
# ============================================================================

# Upstash Redis (for caching and rate limiting)
# Get from: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# ============================================================================
# VOICE SERVICES
# ============================================================================

# Deepgram API Key (for speech-to-text)
# Get from: https://console.deepgram.com/
DEEPGRAM_API_KEY=your-deepgram-api-key

# ElevenLabs API Key (for text-to-speech)
# Get from: https://elevenlabs.io/
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ============================================================================
# VISION AGENTS CONFIGURATION
# ============================================================================

# Frame sampling rate for emotion detection (sample every Nth frame)
# Lower = more frequent analysis but higher API costs
# Recommended: 10 (samples 6 times per second at 60fps)
VISION_AGENTS_FRAME_SAMPLE_RATE=10

# Gemini API rate limit threshold (requests per day)
# When approaching this limit, sampling frequency is automatically reduced
# Gemini Flash-8B free tier: 1000 requests per day
VISION_AGENTS_RATE_LIMIT_THRESHOLD=900

# Minimum words in transcript before requesting AI decision
# Lower = more responsive but higher API costs
# Recommended: 20 words
VISION_AGENTS_DECISION_WORD_THRESHOLD=20

# Seconds of silence to consider as a "long pause"
# Used for speech pattern analysis
VISION_AGENTS_LONG_PAUSE_THRESHOLD=3.0

# Maximum live interview sessions per candidate per day
# Used for rate limiting and cost control
VISION_AGENTS_MAX_SESSIONS_PER_DAY=10

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable/disable Pinecone vector search for questions
USE_PINECONE=true

# Use Claude for interview decisions (high quality, paid)
USE_CLAUDE_DECISION=true

# Use Groq for interview decisions (free tier alternative)
# Set to true and USE_CLAUDE_DECISION to false for free tier
USE_GROQ_DECISION=false

# Enable Supermemory for candidate memory
USE_SUPERMEMORY=true

# Enable Vision Agents for video analysis
USE_VISION=true

# ============================================================================
# NOTES
# ============================================================================

# Required Services for Vision Agents Integration:
# 1. Stream.io (STREAM_APP_ID, STREAM_API_KEY, STREAM_API_SECRET)
# 2. Gemini (GEMINI_API_KEY) - for emotion detection
# 3. Claude (ANTHROPIC_API_KEY) - for interview orchestration
# 4. MongoDB (MONGODB_URI) - for session storage
# 5. Deepgram (DEEPGRAM_API_KEY) - for speech-to-text
# 6. ElevenLabs (ELEVENLABS_API_KEY) - for text-to-speech
#
# Optional Services:
# - Pinecone (PINECONE_API_KEY) - for semantic question search
# - Supermemory (SUPERMEMORY_API_KEY) - for candidate memory
# - Upstash Redis (UPSTASH_REDIS_REST_URL, UPSTASH_REDIS_REST_TOKEN) - for caching
#
# Free Tier Limits:
# - Gemini Flash-8B: 1000 requests per day
# - Groq Llama 3.1 8B: 14,400 requests per day
# - Stream.io: Check your plan limits
# - Deepgram: Check your plan limits
# - ElevenLabs: Check your plan limits
#
# Cost Optimization:
# - Increase VISION_AGENTS_FRAME_SAMPLE_RATE to reduce Gemini API calls
# - Increase VISION_AGENTS_DECISION_WORD_THRESHOLD to reduce Claude API calls
# - Set USE_GROQ_DECISION=true for free tier alternative to Claude
# - Enable Redis caching to reduce TTS API calls
