# Ignore virtual environments
.venv/
venv/
env/

# Ignore Python cache & compiled files
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
htmlcov/

# Ignore environment variables files
.env
.env.*
!.env.example

# Ignore Git files
.git/
.gitignore

# Ignore IDE files
.vscode/
.idea/

# Ignore logs and testing
logs/
*.log

# Ignore data folders with large local files if any
# (assuming questions_normalized.json is needed, but large raw CSVs can be ignored)
data/*.csv
data/*.xlsx
